              { "color": "orange", "value": 30   },
              { "color": "red",    "value": 38   }
            ]
          },
          "mappings": [],
          "unit": "celsius",
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
