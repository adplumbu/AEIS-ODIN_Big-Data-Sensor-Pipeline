              { "color": "red",    "value": 150  }
            ]
          },
          "mappings": [
            { "type": "range", "options": { "from": 0,   "to": 50,  "result": { "text": "Bun"      } } },
            { "type": "range", "options": { "from": 51,  "to": 100, "result": { "text": "Moderat"  } } },
            { "type": "range", "options": { "from": 101, "to": 500, "result": { "text": "Nesănătos"} } }
          ],
          "unit": "short",
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
