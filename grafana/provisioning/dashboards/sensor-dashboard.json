{
  "title": "IoT Sensor Pipeline Dashboard",
  "uid": "sensor-pipeline-dash",
  "description": "Real-time environmental monitoring — 8 Romanian cities | Big Data Project",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "tags": ["iot", "bigdata", "sensors", "environment"],
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "links": [],

  "panels": [

    {
      "id": 1,
      "title": "Total Citiri (ultima oră)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "influxdb-sensors" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-sensors" },
          "query": "from(bucket: \"sensors\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"sensor_reading\")\n  |> filter(fn: (r) => r[\"_field\"] == \"temperature\")\n  |> count()\n  |> group()\n  |> sum()"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },

    {
      "id": 2,
      "title": "Anomalii Detectate (ultima oră)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "influxdb-sensors" },
