        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-sensors" },
          "query": "from(bucket: \"sensors\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"sensor_reading\")\n  |> filter(fn: (r) => r[\"_field\"] == \"temperature\")\n  |> group()\n  |> mean()"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
